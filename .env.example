# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/willguide

# Security & Authentication
# IMPORTANT: Replace with a strong, unique secret in production!
JWT_SECRET=replace_with_strong_secret_key
CORS_ORIGIN=http://localhost:5173

# AI Service (Google Gemini)
# IMPORTANT: Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
AI_PROVIDER=gemini
# Flash is recommended for high-volume ticketing (faster/cheaper). 
# Use 'gemini-3.1-pro-preview' if you need deep reasoning.
AI_RATE_LIMIT=30           # Max requests per minute
AI_MAX_RETRIES=3           # Max retry attempts
AI_CACHE_TTL=3600          # Cache TTL in seconds (1 hour)

# Client URL (for redirects/CORS)
CLIENT_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Telemetry / Error Tracking (optional)
SENTRY_DSN=
REDIS_URL=redis://localhost:6379
